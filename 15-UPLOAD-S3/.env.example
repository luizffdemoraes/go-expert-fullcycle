# MinIO (S3-compatible) - use com docker-compose
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=goexpert-bucket-exemplo
S3_USE_SSL=false

# Para uso dentro da rede Docker (ex.: app em container)
# S3_ENDPOINT=http://minio:9000
